rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Public-site MVP collections used by the website and migration utility.
    match /contentBlocks/{docId} {
      allow read, write: if true;
    }

    match /placements/{docId} {
      allow read, write: if true;
    }

    match /portfolioItems/{docId} {
      allow read, write: if true;
    }

    match /appointments/{docId} {
      allow read, write: if true;
    }

    match /mediaAssets/{docId} {
      allow read, write: if true;
    }

    // Tracks one-time migration runs.
    match /_migrations/{docId} {
      allow read, write: if true;
    }

    // Default deny for anything not explicitly allowed above.
    match /{document=**} {
      allow read, write: if false;
    } 
  }
}
